{
  "name": "bms",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "start:http": "turbo run start --filter=http-server",
    "start:ws": "turbo run start --filter=ws-server",
    "start:web": "turbo run start --filter=web"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.8.10",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}